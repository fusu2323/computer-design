/* pages/map/index.wxss - Map Page Styles */
/* Uses design tokens from app.wxss (--color-*, --space-*) */

.map-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

/* Map container - full screen */
.map-container {
  width: 100%;
  height: 100%;
}

/* Loading overlay */
.loading-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--color-rice-paper);
  padding: var(--space-lg);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-tea-green);
  border-top-color: var(--color-vermilion);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 28rpx;
  color: var(--color-charcoal);
}

/* Error overlay */
.error-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--color-rice-paper);
  padding: var(--space-lg);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.error-text {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 28rpx;
  color: var(--color-vermilion);
}

.error-hint {
  font-family: 'Noto Serif SC', serif;
  font-size: 24rpx;
  color: var(--color-charcoal);
}

/* Category filter chips - horizontal scroll (D-10) */
.filter-chips {
  position: absolute;
  top: 16rpx;
  left: 0;
  right: 0;
  white-space: nowrap;
  padding: 0 var(--space-sm);
  z-index: 1;
}

.chips-row {
  display: inline-flex;
  gap: var(--space-sm);
  padding: var(--space-xs) 0;
}

.chip {
  display: inline-flex;
  align-items: center;
  height: 56rpx;
  padding: 0 var(--space-md);
  background: var(--color-rice-paper);
  border: 2rpx solid var(--color-charcoal);
  border-radius: 28rpx;
}

.chip--active {
  border-color: var(--color-vermilion);
  background: var(--color-vermilion);
}

.chip-text {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 26rpx;
  color: var(--color-charcoal);
}

.chip--active .chip-text {
  color: var(--color-rice-paper);
}

/* Radius preset pills (D-09) */
.radius-presets {
  position: absolute;
  top: 100rpx;
  right: var(--space-sm);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  z-index: 1;
}

/* Navigation bar */
.map-nav-bar {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: var(--space-md);
  z-index: 1;
}

.nav-btn-home,
.nav-btn-create {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  padding: 0 var(--space-xl);
  background: rgba(247, 245, 240, 0.95);
  border: 2rpx solid var(--color-charcoal);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(10px);
}

.nav-btn-create {
  background: var(--color-vermilion);
  border-color: var(--color-vermilion);
}

.nav-btn-text {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 28rpx;
  color: var(--color-ink-black);
}

.nav-btn-create .nav-btn-text {
  color: var(--color-rice-paper);
}

.pill {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 100rpx;
  height: 64rpx;
  padding: 0 var(--space-md);
  background: rgba(247, 245, 240, 0.9);
  border: 2rpx solid var(--color-charcoal);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  backdrop-filter: blur(10px);
}

.pill--active {
  background: var(--color-vermilion);
  border-color: var(--color-vermilion);
}

.pill-text {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 26rpx;
  color: var(--color-ink-black);
}

.pill--active .pill-text {
  color: var(--color-rice-paper);
}

/* Bottom sheet overlay (D-06, D-07) */
.bottom-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100vh;
  background: rgba(0, 0, 0, 0.4);
  z-index: 2;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.bottom-sheet--open {
  opacity: 1;
  pointer-events: auto;
}

.sheet-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 70vh;
  background: var(--color-rice-paper);
  border-radius: 32rpx 32rpx 0 0;
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.bottom-sheet--open .sheet-content {
  transform: translateY(0);
}

/* Handle bar */
.handle-bar {
  width: 80rpx;
  height: 8rpx;
  background: var(--color-charcoal);
  opacity: 0.3;
  border-radius: 4rpx;
  align-self: center;
  margin-bottom: var(--space-sm);
}

/* Site name */
.site-name {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-ink-black);
}

/* Category tag pill */
.category-tag {
  display: inline-flex;
  align-self: flex-start;
  background: var(--color-vermilion);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.tag-text {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 20rpx;
  color: var(--color-rice-paper);
}

/* Hero image */
.hero-image {
  width: 100%;
  height: 320rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin: var(--space-xs) 0;
}

.hero-img {
  width: 100%;
  height: 100%;
}

/* Description */
.description {
  padding: var(--space-sm) 0;
}

.description-text {
  font-family: 'Noto Serif SC', serif;
  font-size: 28rpx;
  color: var(--color-charcoal);
  line-height: 1.6;
}

/* Address row */
.address-row {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.address-icon {
  font-size: 24rpx;
}

.address-text {
  font-family: 'Noto Serif SC', serif;
  font-size: 24rpx;
  color: var(--color-charcoal);
}

/* Distance row */
.distance-row {
  padding: var(--space-xs) 0;
}

.distance-text {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 24rpx;
  color: var(--color-cyan-glaze);
}

/* Navigation CTA button (D-08) */
.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: var(--color-vermilion);
  border-radius: 48rpx;
  margin: var(--space-md) 0 var(--space-lg);
}

.nav-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.nav-btn-text {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-rice-paper);
}

/* Animations */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Debug log overlay */
.debug-log {
  position: fixed;
  top: 120rpx;
  left: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.8);
  padding: 16rpx;
  border-radius: 8rpx;
  z-index: 999;
  max-height: 300rpx;
  overflow: scroll;
}

.debug-text {
  color: #0f0;
  font-size: 20rpx;
  font-family: monospace;
  white-space: pre-wrap;
}
