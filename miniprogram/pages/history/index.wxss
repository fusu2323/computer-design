/* miniprogram/pages/history/index.wxss */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F7F5F0;
}

.creations-scroll {
  flex: 1;
  overflow-y: scroll;
}

.creations-grid {
  padding: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.creation-card {
  aspect-ratio: 1;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(43, 43, 43, 0.1);
  position: relative;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.creation-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(43, 43, 43, 0.15);
}

.creation-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.creation-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 16rpx;
  display: flex;
  align-items: flex-end;
}

.creation-name {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 24rpx;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-icon {
  font-size: 120rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #4A4A4A;
  margin-top: 24rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #CCD4BF;
  border-top-color: #C04851;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
