/* pages/home/index.wxss */
.home-page {
  min-height: 100vh;
  background: var(--color-rice-paper);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: var(--space-xl);
}

/* 顶部标题 */
.app-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-lg) var(--space-sm);
}

.app-title {
  font-family: 'Ma Shan Zheng', cursive;
  font-size: 48rpx;
  color: var(--color-ink-black);
}

.app-subtitle {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 24rpx;
  color: var(--color-charcoal);
  margin-top: var(--space-xs);
}

/* 登录提示 */
.login-prompt {
  margin: var(--space-lg) var(--space-sm);
  padding: var(--space-lg);
}

.prompt-text {
  font-family: 'Noto Serif SC', serif;
  font-size: 28rpx;
  color: var(--color-charcoal);
  text-align: center;
}

/* 知识卡片 */
.knowledge-card {
  background: var(--color-white);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx -2rpx rgba(43, 43, 43, 0.1);
  overflow: hidden;
  margin: var(--space-sm);
  width: calc(100% - var(--space-sm) * 2);
}

.card-image {
  width: 100%;
  height: 400rpx;
  display: block;
}

.card-image-placeholder {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, var(--color-cyan-glaze-light), var(--color-tea-green));
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-image {
  background: linear-gradient(135deg, var(--color-cyan-glaze-light), var(--color-tea-green));
}

.placeholder-text {
  font-family: 'Ma Shan Zheng', cursive;
  font-size: 64rpx;
  color: var(--color-cyan-glaze);
  opacity: 0.6;
}

.card-content {
  padding: var(--space-md);
}

.card-title {
  font-family: 'Ma Shan Zheng', cursive;
  font-size: 36rpx;
  color: var(--color-ink-black);
  display: block;
  margin-bottom: var(--space-sm);
}

.card-tag {
  display: inline-block;
  background: var(--color-cyan-glaze-light);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: var(--space-sm);
}

.tag-text {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 24rpx;
  color: var(--color-cyan-glaze);
}

.card-fact {
  font-family: 'Noto Serif SC', serif;
  font-size: 28rpx;
  color: var(--color-charcoal);
  line-height: 1.6;
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite linear;
  border-radius: 8rpx;
}

/* 错误卡片 */
.error-card {
  background: var(--color-white);
}

.error-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) var(--space-md);
}

.error-title {
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 32rpx;
  color: var(--color-vermilion);
  margin-bottom: var(--space-sm);
}

.error-body {
  font-family: 'Noto Serif SC', serif;
  font-size: 26rpx;
  color: var(--color-charcoal);
}

/* 登录按钮 */
.login-btn {
  background: var(--color-vermilion);
  color: var(--color-white);
  font-family: 'ZCOOL XiaoWei', serif;
  font-size: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 24rpx;
  border: none;
  margin: var(--space-md) var(--space-sm);
  width: calc(100% - var(--space-sm) * 2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn--disabled {
  background: #ccc;
}

.login-btn--loading {
  background: var(--color-vermilion);
  opacity: 0.8;
}

.btn-text {
  color: var(--color-white);
}

.btn-loading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: var(--color-white);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 底部装饰 */
.home-footer {
  margin-top: auto;
  padding: var(--space-lg);
}

.footer-divider {
  width: 120rpx;
  height: 4rpx;
  background: var(--color-tea-green);
  border-radius: 2rpx;
  margin: 0 auto;
}
